# Required: Ducati model to search for (e.g. "Multistrada 1260 Enduro", "Monster 821", "Panigale V4")
BIKE_MODEL=Multistrada 1260 Enduro

EBAY_APP_ID=
EBAY_CERT_ID=

# Browser data directory for persistent cookies and cache.
# Uses .browser_data/ in the project root by default.
# Override with an absolute path to use an existing Chrome profile instead.
BROWSER_DATA_DIR=
