# Required: Ducati model to search for (e.g. "Multistrada 1260 Enduro", "Monster 821", "Panigale V4")
BIKE_MODEL=Multistrada 1260 Enduro

EBAY_APP_ID=
EBAY_CERT_ID=

# Optional: path to a Chrome/Chromium user data directory with existing cookies.
# This helps bypass WAF blocks on sites like Subito.it that block headless browsers.
# Example: BROWSER_DATA_DIR=/Users/you/Library/Application Support/Google/Chrome/Default
BROWSER_DATA_DIR=
